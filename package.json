{
  "name": "hyprmnesia",
  "version": "0.1.4",
  "description": "Personal memory of everything you've seen and heard, queryable via MCP.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "private": true,
  "bin": {
    "hpm": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "start": "bun run src/cli.ts start",
    "build": "bun run build.ts",
    "build:sqlcipher": "bun run scripts/build-sqlcipher.ts",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version && bun run sync-version",
    "sync-version": "bun run scripts/sync-version.ts",
    "package": "bun run scripts/package.ts",
    "checksums": "bun run scripts/checksums.ts",
    "release-notes": "bun run scripts/release-notes.ts",
    "format": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "knip": "knip",
    "knip:fix": "knip --fix"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "get-windows": "^9.3.0",
    "ink": "^7.0.3",
    "react": "^19.2.6",
    "screenshot-desktop": "^1.15.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "knip": "^6.14.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "trustedDependencies": [
    "ffmpeg-static",
    "get-windows"
  ]
}
